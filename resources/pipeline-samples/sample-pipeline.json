{
  "pipeline": {
    "name": "示例 - 多环境构建部署流水线",
    "agent": "any",
    "parameters": [
      {
        "name": "BRANCH",
        "type": "string",
        "defaultValue": "master",
        "description": "要构建的分支"
      },
      {
        "name": "DEPLOY_ENV",
        "type": "choice",
        "choices": ["dev", "staging", "prod"],
        "defaultValue": "dev",
        "description": "部署目标环境"
      }
    ],
    "environment": {
      "APP_NAME": "my-app",
      "REGISTRY": "docker.io/myorg"
    },
    "tools": {
      "maven": "maven3",
      "jdk": "jdk11"
    },
    "stages": [
      {
        "name": "代码检出",
        "steps": [
          { "type": "echo", "message": "检出分支: ${params.BRANCH}" },
          { "type": "checkout" }
        ]
      },
      {
        "name": "编译构建",
        "steps": [
          { "type": "echo", "message": "开始编译..." },
          {
            "type": "sh",
            "command": "mvn clean compile -DskipTests"
          },
          { "type": "echo", "message": "编译完成" }
        ],
        "post": {
          "failure": [{ "type": "echo", "message": "编译失败，请检查日志!" }]
        }
      },
      {
        "name": "单元测试",
        "steps": [
          { "type": "echo", "message": "运行单元测试..." },
          {
            "type": "sh",
            "command": "mvn test"
          },
          {
            "type": "junit",
            "testResults": "**/target/surefire-reports/*.xml"
          }
        ]
      },
      {
        "name": "代码质量检查",
        "when": {
          "branch": "master"
        },
        "steps": [
          {
            "type": "sh",
            "command": "mvn sonar:sonar -Dsonar.projectKey=${APP_NAME}"
          }
        ]
      },
      {
        "name": "打包并推送镜像",
        "steps": [
          { "type": "echo", "message": "构建 Docker 镜像..." },
          {
            "type": "sh",
            "command": "docker build -t ${REGISTRY}/${APP_NAME}:${BUILD_NUMBER} ."
          },
          {
            "type": "sh",
            "command": "docker push ${REGISTRY}/${APP_NAME}:${BUILD_NUMBER}"
          }
        ]
      },
      {
        "name": "部署",
        "steps": [
          {
            "type": "timeout",
            "time": 10,
            "unit": "MINUTES",
            "steps": [
              { "type": "echo", "message": "部署到环境: ${params.DEPLOY_ENV}" },
              {
                "type": "sh",
                "command": "kubectl set image deployment/${APP_NAME} ${APP_NAME}=${REGISTRY}/${APP_NAME}:${BUILD_NUMBER} -n ${params.DEPLOY_ENV}"
              }
            ]
          }
        ],
        "post": {
          "success": [
            { "type": "echo", "message": "部署成功! 版本: ${BUILD_NUMBER}" }
          ],
          "failure": [
            {
              "type": "echo",
              "message": "部署失败! 请检查 Kubernetes 集群状态"
            }
          ]
        }
      }
    ],
    "post": {
      "always": [
        {
          "type": "echo",
          "message": "Pipeline 执行完毕, BUILD_NUMBER=${BUILD_NUMBER}"
        }
      ],
      "success": [
        {
          "type": "echo",
          "message": "构建成功!"
        }
      ],
      "failure": [
        {
          "type": "echo",
          "message": "构建失败，请联系管理员"
        }
      ]
    }
  }
}
